# ── Base de datos (Supabase) ────────────────────────────────────────────────
# Obtén tu connection string en: supabase.com > Project > Settings > Database
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?schema=public"

# ── Stripe ──────────────────────────────────────────────────────────────────
# Claves en: dashboard.stripe.com > Developers > API Keys
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxx"
# Clave pública (para el frontend, si necesitas Stripe.js)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxx"
# Webhook secret: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxx"

# ── Email (Gmail SMTP) ───────────────────────────────────────────────────────
# Para Gmail: activa "Contraseñas de aplicación" en tu cuenta de Google
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="aprendia.store@gmail.com"
SMTP_PASS="xxxx xxxx xxxx xxxx"

# ── URL de la aplicación ─────────────────────────────────────────────────────
NEXT_PUBLIC_URL="https://aprendia-store.vercel.app"

# ── Admin ───────────────────────────────────────────────────────────────────
# Contraseña para el panel de administración en /admin
ADMIN_PASSWORD="cambia-esta-contraseña-segura"
NEXT_PUBLIC_ADMIN_PW="cambia-esta-contraseña-segura"

# ── NextAuth (si usas auth avanzado) ────────────────────────────────────────
NEXTAUTH_SECRET="genera-con: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"
